body {
    font-family: Arial, sans-serif;
    text-align: center;
    background: #f0f8ff;
}

h1 {
    color: #d63384;
}

button {
    padding: 10px 15px;
    margin: 5px;
    border: none;
    background: #4caf50;
    color: white;
    cursor: pointer;
    border-radius: 5px;
}

button:hover {
    background: #45a049;
}

#result {
    margin-top: 15px;
    font-weight: bold;
}
